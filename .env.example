# Sigil — Environment Variable Reference
# Copy this to .env and fill in your values.
# Never commit your real .env to version control.

# ────────────────────────────────────────────────────────────
# REQUIRED — Discord Bot
# ────────────────────────────────────────────────────────────
# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord application / client ID
CLIENT_ID=your_client_id_here

# Guild ID for instant slash-command registration during development.
# Remove or leave blank to register commands globally (takes ~1 hour).
GUILD_ID=your_guild_id_here

# ────────────────────────────────────────────────────────────
# REQUIRED — Gemini AI
# ────────────────────────────────────────────────────────────
# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ────────────────────────────────────────────────────────────
# OPTIONAL — GUI Server
# ────────────────────────────────────────────────────────────
# Port the GUI server listens on (default: 3420)
PORT=3420

# Public URL of the GUI server (used by /gui open in the bot)
# For Railway: set to your Railway public domain
GUI_URL=http://localhost:3420
