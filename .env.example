# ── Discord ────────────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token
CLIENT_ID=your-discord-application-id
GUILD_ID=your-guild-id-for-dev-command-registration

# ── Server ───────────────────────────────────────────────────────────────────────────
PORT=8080

# ── Twitch Integration (Phase 4) ──────────────────────────────────────────────
# Get from: https://dev.twitch.tv/console/apps
# Required for /integrations twitch and the Twitch live poller.
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# ── YouTube Integration (Phase 4) ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com/ → YouTube Data API v3
# Required for /integrations youtube and the YouTube upload poller.
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# ── Webhook HMAC (Phase 3) ─────────────────────────────────────────────────────
# Webhook secrets are stored per-guild in data/sigil.db.
# Generate them in Discord using: /sigilconfig webhook action:Generate new secret
# No env variable needed — listed here for documentation purposes only.
