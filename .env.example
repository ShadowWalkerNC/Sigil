# Discord Bot Token (required)
# Get from: https://discord.com/developers/applications
TOKEN=

# Discord Application / Client ID (required for deploy-commands)
# Found in General Information on the developer portal
CLIENT_ID=

# Gemini API Key (required for AI features)
# Get from: https://aistudio.google.com/app/apikey
# Free tier: 1000 requests/month, no credit card needed
GEMINI_API_KEY=

# GUI Server Port (optional, default 3420)
GUI_PORT=3420

# Database path (optional, default sigil.db in project root)
DB_PATH=sigil.db
