# ──────────────────────────────────────────────────────────────
# Sigil — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Required ───────────────────────────────────────────────────────

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Your bot's Application (Client) ID
CLIENT_ID=

# Your server (guild) ID — used by deploy-commands.js for guild-scoped registration
GUILD_ID=


# ── Twitch Live Alerts (required for /twitch commands) ────────────────
# Create an app at https://dev.twitch.tv/console

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=


# ── YouTube Upload Alerts (optional — RSS fallback works without) ──────
# Get a key at https://console.cloud.google.com → YouTube Data API v3

YOUTUBE_API_KEY=
