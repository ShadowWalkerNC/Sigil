# Discord Bot Token (from https://discord.com/developers/applications)
TOKEN=YOUR_BOT_TOKEN

# Your Discord Application Client ID
CLIENT_ID=YOUR_CLIENT_ID

# The Guild (Server) ID — required when DEPLOY_MODE=guild
GUILD_ID=YOUR_GUILD_ID

# Command deployment mode:
#   guild  — registers commands to GUILD_ID only (instant, best for development)
#   global — registers commands to all servers the bot is in (up to 1hr propagation, use for production)
DEPLOY_MODE=guild

# Google Gemini API Key (from https://aistudio.google.com/app/apikey)
# Used for AI background generation, mood theming, and brand kit AI features
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
